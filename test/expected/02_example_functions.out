-- 02_example_functions.sql: Test the example extension functions
-- Test ConcatArray
SELECT
    concatarray (ARRAY['hello', ' ', 'world']);
 concatarray 
-------------
 hello world
(1 row)

SELECT
    concatarray (ARRAY['a', 'b', 'c']);
 concatarray 
-------------
 abc
(1 row)

SELECT
    concatarray (ARRAY[]::text[]);
 concatarray 
-------------
 
(1 row)

-- Test GzipCompress returns bytea (non-empty)
SELECT
    length(gzipcompress ('hello world'::bytea)) > 0 AS gzip_works;
 gzip_works 
------------
 t
(1 row)

